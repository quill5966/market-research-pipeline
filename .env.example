# ──────────────────────────────────────────────────
# PM News Agent — Environment Configuration
# ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored and takes priority over .env

# ── Required: API Keys ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# ── Required: Domain Configuration ──────────────
# Describe the product domain you want to research
DOMAIN_DESCRIPTION="Enterprise identity and access management (IAM)"

# Comma-separated search queries (no quotes around individual terms)
SEARCH_TERMS="enterprise SSO,identity management,zero trust authentication,CIAM platform,passwordless enterprise"

# ── Optional: LLM Settings ─────────────────────
# MODEL=claude-sonnet-4-6
# TOKEN_BUDGET=50000

# ── Optional: Search Settings ──────────────────
# MAX_RESULTS_PER_TERM=5
# MAX_ARTICLE_CHARS=6000

# Comma-separated domain allowlist/blocklist for Tavily search
# INCLUDE_DOMAINS=bloomberg.com,reuters.com,techcrunch.com
# EXCLUDE_DOMAINS=finance.yahoo.com,msn.com

# ── Optional: Dedup Thresholds ─────────────────
# DEDUP_TITLE_SIMILARITY=0.6
# DEDUP_SNIPPET_SIMILARITY=0.8

# ── Optional: Output ───────────────────────────
# OUTPUT_DIR=output
# LOG_DIR=logs
